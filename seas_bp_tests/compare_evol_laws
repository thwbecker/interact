#!/bin/bash
#
# compare BP5 results for different evolution laws
#

laws="aging slip prz sato"
plaws="$laws"

res=0.5km


ofile=bp5_evol.ps

reg=-R1000/1250/-10/1;xann=a50f5;xl=1010
#reg=-R200/270/-16/1
proj=-JX7/4
#
# vel vs time for 3bs and IMEX solves
#
psbasemap $reg $proj -Y13 -K -P -B$xann:"time [years]":/a2f.5:"@~\341@~log@-10@-(v [m/s])@~\361@~"::."BP5 cycle test @@ $res": > $ofile
pc=1;
yl=0;
for sl in $laws ;do
    sll=`echo $sl | gawk '{print(toupper($1))}'`
    col=`platecolor $pc`
    dir=`./find_directory $sl $res 0`
    gawk '{if(NR>1)print($3,$5)}' $dir/rsf_monitor.dat | \
	psxy -W2,$col $reg $proj -O -K >> $ofile
    dir=`./find_directory $sl $res 1`
    gawk '{if(NR>1)print($3,$5)}' $dir/rsf_monitor.dat | \
	psxy -W3,$col,. $reg $proj -O -K >> $ofile
    echo $xl $yl 18 0 29 LM $sll | pstext -R -J -O -K -F+f$col >> $ofile
    ((yl=yl-1))
    ((pc=pc+1))
done
#psxy -T -O -R >> $ofile;modifybb $ofile
#exit

pc=1;xl=0.52;xl2=0.5;yl=-2
reg=-R0.48/0.6/-10/1.5		# phase space
by_color=0			# colored lines single plot, 0: several plots
pc=1
if [ $by_color = 1 ];then
    proj=-JX7/4
    psbasemap $reg $proj -Y-5 -K -O -Ba.025f0.0025:"mean friction @~\341m\361@~":/a2f.5:"@~\341@~log@-10@-(v [m/s])@~\361@~": >> $ofile

    for sl in $laws ;do
	dir=`./find_directory $sl $res 0`
	sll=`echo $sl | gawk '{print(toupper($1))}'`
	col=`platecolor $pc`
	gawk '{if(NR>1)if($3>1000)if($3>1250)print($7,$5)}' $dir/rsf_monitor.dat | \
	    psxy -W1,$col $reg $proj -O -K >> $ofile
	echo $xl $yl 18 0 29 LM $sll | pstext -R -J -O -K -F+f$col >> $ofile
	yl=$(bc <<< "$yl - 1.5")
	((pc=pc+1))
    done
else
    makecpt -Croma -I -T0/1/0.01 > time.cpt
    #makecpt -Csplit -T0/1/0.05 > time.cpt
    proj=-JX3.4/4
    for sl in $plaws;do
	dir=`./find_directory $sl $res 0`
	sll=`echo $sl | gawk '{print(toupper($1))}'`
	if [ $pc -eq 1 ];then
	    ae=WesN;off="-Y-5"
	elif [ $pc -eq 2 ];then
	    ae=wEsN;off="-X3.5"
	elif [ $pc -eq 3 ];then
	    ae=WeSn;off="-X-3.5 -Y-4.75"
	elif [ $pc -eq 4 ];then
	    ae=wESn;off="-X3.5"
	fi
	psbasemap $reg $proj $off -K -O \
		  -Ba.025f0.005g0.025:"mean friction @~\341m\361@~":/g3a3f.5:"@~\341@~log@-10@-(v [m/s])@~\361@~":$ae >> $ofile
	sym=-SC
	# find the right time to adjust
	#gawk '{if($3==-1)print($2)}' $dir/rsf_events.dat | tail -2 | gawk -f torow.awk > tmp.val
	tail -2 $dir/rsf_catalog.dat | gawk '{if(NR==1)print($3);else print($3)}' | gawk -f torow.awk > tmp.val
	
	read t1 t2 < tmp.val; rm tmp.val
	echo $sl $t1 $t2
	gawk -v t1=$t1 -v t2=$t2 '{if(NR>1)if($3>=t1)if($3<=t2)print($7,$5,($3-t1)/(t2-t1))}' $dir/rsf_monitor.dat > tmp.dat
	if [ $pc -eq 1 ];then
	    gawk '{print($1,$2)}' tmp.dat > tmp.back
	fi
	psxy tmp.back -W3,gray $reg $proj -O -K >> $ofile
	gawk -f xyval2seg.awk tmp.dat | psxy -m  $reg $proj -O -K -W2 -Ctime.cpt >> $ofile
	psxy tmp.dat $sym".05" $reg $proj -O -K -Ctime.cpt >> $ofile
	if [ $pc -eq 2 ];then
	    psscale -D0/-0.25/4/.15h -Ctime.cpt -O -K -B0.2/:"t/T": >> $ofile
	fi
	echo $xl2 -2 22 0 29 LM "$sll" | pstext -R -O -Gwhite -J -K >> $ofile
	rm tmp.dat
	((pc=pc+1))
    done
    rm tmp.back
fi

psxy -T -O >> $ofile
modifybb $ofile 1
